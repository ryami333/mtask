{
  "name": "mtask",
  "version": "1.0.0",
  "description": "A minimal Electron application written with Typescript",
  "engines": {
    "node": "^22.18.0"
  },
  "scripts": {
    "build": "node build.mjs",
    "dev:build": "nodemon --watch src --ext \"*\" --exec \"yarn build\"",
    "dev:start": "nodemon --watch dist --ext \"*\" --exec \"yarn start\"",
    "dev": "concurrently -k -p \"[{name}]\" -n \"Build,Start\" \"yarn dev:build\" \"yarn dev:start\"",
    "lint": "eslint .",
    "start": "electron-forge start",
    "build:icons": "electron-icon-builder --flatten --input=./check-mark-button.png --output=.",
    "package": "NODE_ENV=production yarn build && yarn build:icons && electron-forge package",
    "make": "electron-forge make",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "main": "./dist/main.js",
  "repository": "https://github.com/electron/electron-quick-start-typescript",
  "keywords": [
    "Electron",
    "quick",
    "start",
    "tutorial",
    "demo",
    "typescript"
  ],
  "author": "GitHub",
  "license": "CC0-1.0",
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "@eslint/js": "^10.0.1",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/addon-links": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@types/node": "22.19.21",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "concurrently": "^10.0.3",
    "electron": "^42.4.1",
    "electron-icon-builder": "^2.0.1",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-storybook": "10.4.6",
    "globals": "^17.6.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.4",
    "storybook": "^10.4.6",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "polished": "^4.3.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.79.0",
    "source-map-support": "^0.5.21",
    "styled-components": "6.4.2",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  },
  "config": {
    "forge": {
      "packagerConfig": {
        "name": "mtask",
        "executableName": "mtask",
        "icon": "./icons/icon"
      },
      "makers": [
        {
          "name": "@electron-forge/maker-zip",
          "platforms": [
            "darwin"
          ]
        }
      ]
    }
  },
  "packageManager": "yarn@4.17.0"
}
