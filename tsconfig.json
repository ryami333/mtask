{
  "compilerOptions": {
    "jsx": "react",
    "module": "esnext",
    "moduleResolution": "bundler",
    "noImplicitAny": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "lib": ["dom", "es2022"],
    "outDir": "dist",
    "noEmit": true,
    "allowJs": true,
    "checkJs": true,
    "strict": true,
    "esModuleInterop": true,
    "types": ["vite/client", "node"]
  },
  "include": ["**/*.ts", "**/*.tsx", "**/*.js", "**/*.jsx"]
}
